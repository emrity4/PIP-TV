<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true"
    android:background="#0F0F0F">

    <com.google.android.exoplayer2.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:background="#000000"
        app:use_controller="false" />

    <LinearLayout
        android:id="@+id/pause_indicator"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:background="@drawable/pause_bg"
        android:visibility="gone"
        android:animateLayoutChanges="true">

        <WebView
            android:id="@+id/pause_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@android:color/transparent" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginTop="20dp"
        android:layout_marginStart="16dp"
        android:orientation="horizontal"
        android:elevation="6dp"
        android:background="#CC0A0A0B"
        android:padding="6dp">

        <TextView
            android:id="@+id/hamburger_button"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:gravity="center"
            android:text="☰"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/toolbar_btn_bg" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="400dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:background="#E50A0A0B"
        android:translationX="400dp">

        <TextView
            android:id="@+id/sidebar_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/channels"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingTop="28dp"
            android:paddingBottom="6dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:letterSpacing="0.04" />

        <TextView
            android:id="@+id/channel_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="227 channels"
            android:textColor="#A0A0A8"
            android:textSize="13sp"
            android:paddingBottom="12dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:letterSpacing="0.03" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2C2C2E"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/channel_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="160dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:scrollbarStyle="outsideOverlay" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/now_playing_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginTop="88dp"
        android:layout_marginStart="20dp"
        android:orientation="horizontal"
        android:elevation="4dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/now_playing_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:background="#E5121315" />

        <TextView
            android:id="@+id/live_badge"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="● LIVE"
            android:textColor="#FF453A"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:paddingStart="4dp"
            android:paddingEnd="14dp"
            android:background="#E5121315" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/loading_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:indeterminateTint="#FF7A35" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/loading_channels"
            android:textColor="#A0A0A8"
            android:textSize="15sp"
            android:layout_marginTop="20dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/error_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/error_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:gravity="center"
            android:maxWidth="300dp" />

        <Button
            android:id="@+id/retry_button"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/retry"
            android:layout_marginTop="20dp"
            android:backgroundTint="#FF7A35"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:paddingStart="32dp"
            android:paddingEnd="32dp" />
    </LinearLayout>

    <WebView
        android:id="@+id/splash_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible" />

    <LinearLayout
        android:id="@+id/empty_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_channels"
            android:textColor="#A0A0A8"
            android:textSize="16sp" />
    </LinearLayout>

</FrameLayout>
